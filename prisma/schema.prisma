// Locker database schema
// ------------------------------------------------------------------
// Design rules that keep this future-proof (the "5M users" test):
//  1. UUID primary keys        -> no hot auto-increment, safe to shard/merge.
//  2. schoolId on tenant tables -> partition/shard by school later, no rewrite.
//  3. createdAt/updatedAt/deletedAt -> auditability + soft deletes everywhere.
//  4. metadata Json? on extensible tables -> new module fields need NO migration.
//  5. Modules are self-contained sets of tables that reference the shared
//     User/School/Class/Membership core. New modules add tables; they never
//     alter existing ones.
// ------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries go through the transaction-mode pooler (pgbouncer).
  url       = env("DATABASE_URL")
  // Migrations / db push need a direct (session-mode) connection.
  directUrl = env("DIRECT_URL")
}

// ============================================================
// CORE IDENTITY & TENANCY
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  // Set the moment email verification succeeds; null means "can't sign in
  // yet" (see core/auth/auth.ts's authorize()). Doubles as the boolean gate
  // and an audit timestamp of when the account became real.
  emailVerified DateTime?
  passwordHash  String    // every account is email+password now — always required
  name          String    // required at signup — there is no path to an unnamed account anymore
  nickname      String?
  bio           String?
  image         String?
  handle        String?   @unique // public @name, claimed lazily
  metadata      Json?     // escape hatch for future profile fields with no migration

  // Login brute-force protection (see core/auth/auth.ts authorize()): a
  // simple DB-backed counter/lockout. No Redis in this project, so this is
  // the practical option rather than a distributed rate limiter.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  memberships        Membership[]
  homeworkCreated    Homework[]          @relation("HomeworkAuthor")
  homeworkStatuses   HomeworkStatus[]
  listings           MarketplaceListing[]
  achievements       Achievement[]       // real-life accomplishments — the portfolio
  invitesSent        Invite[]            @relation("InviteInviter")
  invitedBy          Invite?             @relation("InviteAccepted")
  notifications      Notification[]

  // Group Finder (project workspaces). Leadership is tracked via
  // GroupMember.role (LEADER), not a separate FK — a Group has exactly one
  // LEADER member at a time, enforced in app logic (transferLeadership).
  groupMemberships       GroupMember[]
  groupJoinRequests      GroupJoinRequest[]    @relation("GroupJoinRequester")
  groupJoinRequestsDecided GroupJoinRequest[]  @relation("GroupJoinDecider")
  tasksAssigned          GroupTask[]           @relation("TaskAssignee")
  tasksCreated           GroupTask[]           @relation("TaskCreator")
  resourcesUploaded      GroupResource[]
  groupActivities        GroupActivity[]
  deletionVotesStarted   GroupDeletionVote[]
  deletionBallots        GroupDeletionBallot[]
  groupMessages          GroupMessage[]

  // Ownership & moderation (student-first: a student who creates a school or
  // class owns it outright — no approval step gates their ability to use Locker).
  foundedSchools          School[]          @relation("SchoolFounder")
  foundedClasses          Class[]           @relation("ClassFounder")
  schoolModeratorRoles    SchoolModerator[] @relation("SchoolModeratorUser")
  schoolModeratorGrants   SchoolModerator[] @relation("SchoolModeratorGrantedBy")
  teacherOfClasses        Class[]           @relation("ClassTeacher") // reserved, unused until teacher verification ships

  passwordResetCodes PasswordResetCode[]

  // Direct messages — user1/user2 relation names below.
  conversationsAsUser1 Conversation[]  @relation("ConversationUser1")
  conversationsAsUser2 Conversation[]  @relation("ConversationUser2")
  directMessagesSent   DirectMessage[]

  // Rewards (points/badges/streaks/perks) — platform engagement
  // gamification, kept deliberately separate from Achievement (real-life
  // accomplishments have no points, on purpose — see that model's comment).
  progress     UserProgress?
  pointEntries PointEntry[]
  badges       UserBadge[]
  perks        UserPerk[]
  celebrations Celebration[]
}

model School {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique // e.g. "lincoln-high"
  domain    String?  // optional email domain for auto-join, e.g. "@lincoln.edu"
  founderId String   // whichever student created the school owns it — no gatekeeping
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  founder    User              @relation("SchoolFounder", fields: [founderId], references: [id])
  classes    Class[]
  listings   MarketplaceListing[]
  moderators SchoolModerator[]

  @@index([slug])
  @@index([founderId])
}

// School-wide moderators, assigned by the School Founder. Distinct from class
// Membership because a school moderator's authority spans every class in the
// school, not just one they're a member of.
model SchoolModerator {
  id            String   @id @default(uuid())
  schoolId      String
  userId        String
  grantedById   String
  createdAt     DateTime @default(now())

  school    School @relation(fields: [schoolId], references: [id])
  user      User   @relation("SchoolModeratorUser", fields: [userId], references: [id])
  grantedBy User   @relation("SchoolModeratorGrantedBy", fields: [grantedById], references: [id])

  @@unique([schoolId, userId])
  @@index([schoolId])
}

enum ClassStatus {
  ACTIVE
  ARCHIVED // set by the Class Founder — hides it without deleting history
  REMOVED  // set by the School Founder as a moderation action
}

model Class {
  id         String      @id @default(uuid())
  schoolId   String
  founderId  String      // whichever student created the class owns it
  teacherId  String?     // reserved: set once a verified teacher claims the class (not implemented yet)
  name       String      // "Grade 10-B" or "AP Biology - Period 3"
  subject    String?
  status     ClassStatus @default(ACTIVE)
  inviteCode String      @unique // the growth engine: joining requires this — also doubles as the invite link/QR payload
  metadata   Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  school      School       @relation(fields: [schoolId], references: [id])
  founder     User         @relation("ClassFounder", fields: [founderId], references: [id])
  teacher     User?        @relation("ClassTeacher", fields: [teacherId], references: [id])
  memberships Membership[]
  homework    Homework[]
  groups      Group[]

  @@index([schoolId])
  @@index([inviteCode])
  @@index([founderId])
}

// Class-scoped role. FOUNDER = created the class. MODERATOR = promoted by the
// founder. TEACHER is reserved for the future claim flow (see Class.teacherId)
// and is not assignable anywhere in current app logic.
enum Role {
  STUDENT
  MODERATOR
  FOUNDER
  TEACHER
}

// User <-> Class join. Also the unit we count for "class size" growth gates.
model Membership {
  id        String   @id @default(uuid())
  userId    String
  classId   String
  schoolId  String   // denormalized for fast school-scoped queries + sharding
  role      Role     @default(STUDENT)
  verified  Boolean  @default(false) // confirmed by >=2 existing members
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  class Class @relation(fields: [classId], references: [id])

  @@unique([userId, classId])
  @@index([classId])
  @@index([schoolId])
}

// ============================================================
// MODULE: HOMEWORK
// ============================================================

model Homework {
  id          String   @id @default(uuid())
  classId     String
  authorId    String   // first person to add it gets contribution credit
  title       String
  description String?
  subject     String?
  dueAt       DateTime?
  confirmations Int    @default(1) // how many members vouch it's real -> coverage meter
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  class    Class            @relation(fields: [classId], references: [id])
  author   User             @relation("HomeworkAuthor", fields: [authorId], references: [id])
  statuses HomeworkStatus[]

  @@index([classId, dueAt])
}

// Per-user done/not-done. This table IS the daily engagement signal.
model HomeworkStatus {
  id         String    @id @default(uuid())
  homeworkId String
  userId     String
  done       Boolean   @default(false)
  doneAt     DateTime?

  homework Homework @relation(fields: [homeworkId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([homeworkId, userId])
  @@index([userId])
}

// ============================================================
// MODULE: MARKETPLACE  (school-scoped for liquidity)
// ============================================================

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
}

model MarketplaceListing {
  id          String        @id @default(uuid())
  schoolId    String
  sellerId    String
  title       String
  description String?
  priceCents  Int           @default(0) // integer money, never floats
  currency    String        @default("USD")
  images      String[]      @default([])
  status      ListingStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  school School @relation(fields: [schoolId], references: [id])
  seller User   @relation(fields: [sellerId], references: [id])

  @@index([schoolId, status])
}

// ============================================================
// MODULE: REWARDS  (points, badges, streaks, perks — platform engagement
// gamification. Deliberately separate from Achievement, which is a
// real-life-accomplishment portfolio with no points, on purpose — grinding
// XP should never be confusable with a verified competition result.)
//
// Definitions (Badge/Perk/LevelDef/PointAction) are DATA, not code: adding
// one is an INSERT, never a code change. Unlock/award logic is one generic
// evaluator per concept, reading condition fields off the row — see
// src/core/rewards/engine.ts. Never add a per-badge `if` there.
// ============================================================

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

// What a badge's unlock condition is measured against — computed fresh
// per user by src/core/rewards/stats.ts.
enum ConditionStat {
  HOMEWORK_COMPLETED
  RESOURCES_UPLOADED
  GROUPS_JOINED
  GROUPS_CREATED
  CURRENT_STREAK
  LONGEST_STREAK
  TOTAL_POINTS_EARNED
  ACCOUNT_RANK    // 1-based signup order; lower = earlier (for "Early Adopter")
  ONBOARDING_DONE // 0 or 1
}

enum ConditionOp {
  GTE // >= value
  LTE // <= value — only useful for ACCOUNT_RANK ("among the first N")
}

model Badge {
  id             String        @id @default(uuid())
  key            String        @unique // "homework_hero", "consistency_30"
  name           String
  description    String
  icon           String        // emoji
  rarity         Rarity        @default(COMMON)
  conditionStat  ConditionStat
  conditionOp    ConditionOp   @default(GTE)
  conditionValue Int
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())

  unlocks UserBadge[]

  @@index([conditionStat])
}

model UserBadge {
  id         String   @id @default(uuid())
  badgeId    String
  userId     String
  unlockedAt DateTime @default(now())

  badge Badge @relation(fields: [badgeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([badgeId, userId])
  @@index([userId])
}

// A perk occupies a "slot" — at most one perk per slot can be equipped at
// once (e.g. only one name color active), except UTILITY, which is a
// consumable stockpile (shields, revival tokens), not equippable at all.
enum PerkSlot {
  NAME_COLOR
  AVATAR_FRAME
  CHAT_BUBBLE
  CELEBRATION_EFFECT
  COSMETIC_BADGE
  UTILITY
}

model Perk {
  id          String   @id @default(uuid())
  key         String   @unique // "name_color_gold", "streak_shield"
  name        String
  description String
  icon        String
  rarity      Rarity   @default(COMMON)
  slot        PerkSlot
  price       Int      // in points; 0 = never purchasable, streak-granted only
  purchasable Boolean  @default(true)
  value       String?  // hex color / css class / effect key — read by the slot's own renderer, never branched on by key
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  owners UserPerk[]
}

model UserPerk {
  id         String   @id @default(uuid())
  perkId     String
  userId     String
  acquiredAt DateTime @default(now())
  equipped   Boolean  @default(false)
  quantity   Int      @default(1) // consumables only (UTILITY slot)

  perk Perk @relation(fields: [perkId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([perkId, userId])
  @@index([userId])
}

// Level curve as data — cumulative totalEarned required per level, plus
// optional flavor title. Tuning the curve is an edit to seeded rows, never
// a formula change.
model LevelDef {
  level        Int     @id
  pointsNeeded Int
  title        String?
}

enum DedupScope {
  NONE            // always awardable, subject only to cooldownSec
  PER_REF         // once per (user, action, refId), forever — e.g. one award per homeworkId
  PER_DAY         // once per (user, action) per calendar day — e.g. daily login
  PER_REF_PER_DAY // once per (user, action, refId) per calendar day — e.g. one group's chat/day
}

// Point-earning action catalog. awardPoints(userId, key, refId?) looks
// itself up here — cooldown/dedup enforcement is generic, keyed off these
// fields, never a per-action special case.
model PointAction {
  key         String     @id
  name        String
  points      Int
  dedupScope  DedupScope @default(NONE)
  cooldownSec Int        @default(0)
  enabled     Boolean    @default(true)
}

// Append-only audit log of every point award. This table IS the mechanism
// for cooldowns, dedup, and time-windowed leaderboards (weekly/monthly sum
// straight off createdAt) — not a side effect of them.
model PointEntry {
  id        String   @id @default(uuid())
  userId    String
  action    String
  points    Int
  refId     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, action, refId])
  @@index([action, createdAt])
}

model UserProgress {
  userId        String    @id
  points        Int       @default(0) // spendable balance
  totalEarned   Int       @default(0) // lifetime — the contribution score; never decreases on spend
  level         Int       @default(1)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastActiveOn  DateTime? // date-granularity check-in marker, drives streak math
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// One row per celebration-worthy moment (badge unlocked, level up, perk
// granted, streak milestone) — a single unseen-flag queue the app shell
// drains into celebration modals, instead of scattering a `seen` column
// across every different reward type.
enum CelebrationType {
  BADGE
  LEVEL_UP
  PERK
  STREAK_MILESTONE
}

model Celebration {
  id          String          @id @default(uuid())
  userId      String
  type        CelebrationType
  title       String
  description String?
  icon        String?
  rarity      Rarity?
  seen        Boolean         @default(false)
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, seen])
}

// ============================================================
// MODULE: ACHIEVEMENTS  (student portfolio — real-life accomplishments)
// ============================================================

enum AchievementCategory {
  SPORTS
  ACADEMICS
  CODING
  ART
  MUSIC
  DRAMA
  DEBATE
  MUN
  VOLUNTEERING
  CERTIFICATION
  READING
  SCIENCE
  PHOTOGRAPHY
  OTHER
}

enum AchievementLevel {
  SCHOOL
  INTER_SCHOOL
  DISTRICT
  STATE
  NATIONAL
  INTERNATIONAL
}

// Reserved for future moderator/teacher review of submitted achievements.
// No verification workflow exists yet — every achievement is created UNVERIFIED
// and stays that way until that feature ships.
enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum Visibility {
  PRIVATE
  CLASS_ONLY
  PUBLIC
}

// A real-life accomplishment a student is proud of — the "LinkedIn for
// students" portfolio. Deliberately NOT a gamification table: no points here.
model Achievement {
  id                 String              @id @default(uuid())
  userId             String
  title              String
  category           AchievementCategory
  description        String?
  level              AchievementLevel
  achievedOn         DateTime // when the accomplishment actually happened
  // File uploads aren't wired yet (no object storage configured) — these are
  // plain URLs for now. Swap for real upload storage (e.g. Supabase Storage)
  // without a schema change: the column shape doesn't need to move.
  certificateUrl     String?
  photoUrl           String?
  link               String?
  verificationStatus VerificationStatus  @default(UNVERIFIED)
  visibility         Visibility          @default(PUBLIC)
  metadata           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, level])
}

// ============================================================
// MODULE: GROUP FINDER  (student project workspaces)
// ------------------------------------------------------------------
// A Group is a real school project, not a chat room. Joining requires
// Group Leader approval (GroupJoinRequest) — never automatic. Each project
// carries its own tasks, resources, and activity feed. Deletion is a member
// vote, never a unilateral leader action (GroupDeletionVote) — the group is
// archived (soft-deleted) on success, never hard-deleted.
// ============================================================

enum ProjectStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  ARCHIVED // set by the leader directly, or by a successful deletion vote
}

// LEADER = created the project (exactly one at a time — enforced in app
// logic via transferLeadership, which atomically demotes the old leader).
// CO_LEADER = promoted by the Leader; can manage day-to-day project work but
// not governance (removing members, transferring ownership, deletion votes).
enum GroupRole {
  LEADER
  CO_LEADER
  MEMBER
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// "Google Doc / Slides / Drive folder" are their own types (not just LINK)
// so the UI can show the right icon without parsing the URL.
enum ResourceType {
  NOTE
  PDF
  DOCUMENT
  PRESENTATION
  IMAGE
  LINK
  GOOGLE_DOC
  GOOGLE_SLIDES
  GOOGLE_DRIVE
  OTHER
}

enum DeletionVoteStatus {
  OPEN
  PASSED // >50% of current members voted DELETE -> group archived
  FAILED // resolved, not enough DELETE votes
  TIED   // equal DELETE/KEEP with all members voted -> not deleted, must restart
}

enum VoteChoice {
  DELETE
  KEEP
}

model Group {
  id          String        @id @default(uuid())
  classId     String
  name        String
  subject     String?
  description String?
  teacherName String?       // plain text for now — no Teacher entity/verification yet
  dueAt       DateTime?
  status      ProjectStatus @default(UPCOMING)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  archivedAt  DateTime?
  deletedAt   DateTime?

  class         Class                @relation(fields: [classId], references: [id])
  members       GroupMember[]
  joinRequests  GroupJoinRequest[]
  tasks         GroupTask[]
  resources     GroupResource[]
  activities    GroupActivity[]
  deletionVotes GroupDeletionVote[]
  messages      GroupMessage[]

  @@index([classId, status])
}

// In-project chat. Deliberately NOT logged to GroupActivity — that feed is
// for "important activity" (spec's own words); message-by-message chat would
// drown it out. Polled from the client (~3s), not pushed — there's no
// websocket/realtime infra in this app, and that's an honest, bounded cost
// for a small project chat rather than new always-on infrastructure.
model GroupMessage {
  id        String    @id @default(uuid())
  groupId   String
  authorId  String
  content   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  group  Group @relation(fields: [groupId], references: [id])
  author User  @relation(fields: [authorId], references: [id])

  @@index([groupId, createdAt])
}

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId, role])
}

// Joining is never automatic — every request needs a Leader/Co-Leader decision.
model GroupJoinRequest {
  id          String            @id @default(uuid())
  groupId     String
  userId      String
  message     String?
  status      JoinRequestStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  decidedAt   DateTime?
  decidedById String?

  group     Group @relation(fields: [groupId], references: [id])
  user      User  @relation("GroupJoinRequester", fields: [userId], references: [id])
  decidedBy User? @relation("GroupJoinDecider", fields: [decidedById], references: [id])

  @@index([groupId, status])
}

model GroupTask {
  id          String     @id @default(uuid())
  groupId     String
  title       String
  description String?
  assigneeId  String?
  status      TaskStatus @default(NOT_STARTED)
  dueAt       DateTime?
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  completedAt DateTime?

  group     Group @relation(fields: [groupId], references: [id])
  assignee  User? @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy User  @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([groupId, status])
}

model GroupResource {
  id          String       @id @default(uuid())
  groupId     String
  title       String
  description String?
  type        ResourceType
  // File uploads aren't wired yet (no object storage configured) — this is a
  // plain URL for now (external link, or a future Supabase Storage URL).
  // Same column shape either way, so no migration is needed to add real
  // uploads later.
  url         String
  uploaderId  String
  createdAt   DateTime     @default(now())
  deletedAt   DateTime?

  group    Group @relation(fields: [groupId], references: [id])
  uploader User  @relation(fields: [uploaderId], references: [id])

  @@index([groupId])
}

// Denormalized, precomputed display strings (type + message) rather than a
// fully structured event-sourcing table — this feed is read far more often
// than it's analyzed, so optimizing for "render instantly" beats "queryable
// by arbitrary event shape."
model GroupActivity {
  id        String   @id @default(uuid())
  groupId   String
  actorId   String
  type      String   // "created" | "join_requested" | "member_joined" | "member_removed" | "resource_added" | "task_created" | "task_assigned" | "task_completed" | "role_changed" | "leader_transferred" | "deadline_changed" | "details_updated" | "deletion_vote_started" | "deletion_vote_resolved" | "archived"
  message   String   // "Aryan requested to join"
  metadata  Json?
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  actor User  @relation(fields: [actorId], references: [id])

  @@index([groupId, createdAt])
}

// Only the Leader can start one; resolves once every CURRENT member has
// voted. >50% DELETE -> group archived. Equal split -> TIED, group survives.
model GroupDeletionVote {
  id            String             @id @default(uuid())
  groupId       String
  initiatedById String
  status        DeletionVoteStatus @default(OPEN)
  createdAt     DateTime           @default(now())
  resolvedAt    DateTime?

  group         Group                 @relation(fields: [groupId], references: [id])
  initiatedBy   User                  @relation(fields: [initiatedById], references: [id])
  ballots       GroupDeletionBallot[]

  @@index([groupId])
}

model GroupDeletionBallot {
  id        String     @id @default(uuid())
  voteId    String
  userId    String
  choice    VoteChoice
  createdAt DateTime   @default(now())

  vote GroupDeletionVote @relation(fields: [voteId], references: [id])
  user User              @relation(fields: [userId], references: [id])

  @@unique([voteId, userId])
}

// ============================================================
// CORE: NOTIFICATIONS
// ------------------------------------------------------------------
// Generic and reusable beyond Group Finder on purpose — DB-backed and
// polled on page load (no websockets/push yet), matching the rest of the
// app's server-rendered style. `link` sends the click straight to the
// relevant page (e.g. a group's dashboard).
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  link      String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
}

// ============================================================
// GROWTH: INVITE ATTRIBUTION
// ============================================================

model Invite {
  id         String    @id @default(uuid())
  code       String    @unique
  inviterId  String
  classId    String?   // invite can be to a specific class
  acceptedById String? @unique
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  inviter    User  @relation("InviteInviter", fields: [inviterId], references: [id])
  acceptedBy User? @relation("InviteAccepted", fields: [acceptedById], references: [id])

  @@index([inviterId])
}

// ============================================================
// AUTH: email/password + OTP verification
// ------------------------------------------------------------------
// No adapter, no OAuth tables — Credentials-only auth with JWT sessions
// needs neither. A signup does NOT create a User row: it creates a
// PendingRegistration (hashed password already, since we never want a
// plaintext password sitting around even temporarily) that only becomes a
// real User once the 6-digit code is verified. PasswordResetCode follows the
// same shape for the forgot-password flow.
// ============================================================

model PendingRegistration {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  passwordHash  String
  code          String   // 6-digit, plaintext — brute force is stopped by
                          // `attempts` + expiry, not by hashing a 1-in-a-
                          // million numeric code (hashing wouldn't change the
                          // search space, only add latency).
  codeExpiresAt DateTime
  attempts      Int      @default(0)
  lastSentAt    DateTime @default(now()) // resend cooldown (60s)
  createdAt     DateTime @default(now())
}

model PasswordResetCode {
  id            String    @id @default(uuid())
  userId        String
  code          String
  codeExpiresAt DateTime
  attempts      Int       @default(0)
  usedAt        DateTime? // single-use: set the moment a reset succeeds
  lastSentAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================================
// DIRECT MESSAGES
// ============================================================

// Exactly one conversation per unordered pair of users. user1Id is always
// the lexicographically smaller id (enforced in app code at creation time),
// so the @@unique constraint catches both orderings of the same pair
// instead of needing an OR query or a second row.
model Conversation {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())

  // Per-participant read tracking — cheap way to derive unread counts
  // without a separate read-receipts table, since a DM conversation only
  // ever has two participants.
  user1LastReadAt DateTime?
  user2LastReadAt DateTime?

  user1    User            @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2    User            @relation("ConversationUser2", fields: [user2Id], references: [id])
  messages DirectMessage[]

  @@unique([user1Id, user2Id])
  @@index([user2Id])
}

model DirectMessage {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}
