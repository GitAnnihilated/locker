# --- Database ---
# Local: postgres://user:pass@localhost:5432/locker
# Managed (Neon/Supabase): use the pooled connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/locker?schema=public"
# Direct (non-pooled) connection, used by Prisma for migrations / db push.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/locker?schema=public"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-me"
# Canonical base URL Auth.js uses to build callback URLs.
AUTH_URL="http://localhost:3000"

# --- Resend (transactional email: verification codes, password resets) ---
# Get a key at https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxx"
# Must be an address on a domain you've verified in Resend. The shared
# "onboarding@resend.dev" sender works with zero setup but can only deliver
# to your own Resend account email — fine for local dev, not for real users.
RESEND_FROM_EMAIL="Locker <onboarding@resend.dev>"

# Public base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
